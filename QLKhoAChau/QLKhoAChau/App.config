<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
    <connectionStrings>
        <!-- Sửa Data Source thành tên SQL Server của bạn (vd: .\SQLEXPRESS) -->
        <add name="QLKho"
             connectionString="Data Source=.;Initial Catalog=QLKho_AChau;Integrated Security=True;TrustServerCertificate=True"
             providerName="System.Data.SqlClient"/>
    </connectionStrings>
</configuration>
